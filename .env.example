# Copy to .env for local runs.

# Required for Telegram delivery.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# API-Football / API-Sports.
API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_LEAGUE_ID=1
API_FOOTBALL_SEASON=2026

# Data inputs. FIXTURES_URL can point at a vendor or your own normalized feed.
FIXTURES_PATH=data/fixtures.json
FIXTURES_URL=
TEAM_RATINGS_PATH=data/team_ratings.json
TEAM_CONTEXT_PATH=data/team_context.json
TELEGRAM_ALERTS_ONLY=true
TOURNAMENT_SIMULATIONS=20000
TOURNAMENT_SEED=2026

# Report behavior.
REPORT_LOOKAHEAD_HOURS=72
EDGE_THRESHOLD=0.15
MIN_MARKET_LIQUIDITY=0
TIMEZONE=Asia/Hong_Kong

# Polymarket public APIs.
POLYMARKET_GAMMA_BASE_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_BASE_URL=https://clob.polymarket.com
POLYMARKET_SEARCH_TEMPLATE="FIFA World Cup 2026 {team_a} {team_b}"

# Persistence.
DATABASE_PATH=reports/fifa_agent.sqlite3
